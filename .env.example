# TikTok API Credentials
TIKTOK_ACCESS_TOKEN=your_tiktok_access_token_here
TIKTOK_VIDEO_UPLOADER_ID=your_uploader_id_here

# OpenAI API Key (for joke generation)
OPENAI_API_KEY=your_openai_api_key_here

# Google Cloud (for text-to-speech)
GOOGLE_APPLICATION_CREDENTIALS=path/to/google-cloud-key.json

# Bot Settings
BOT_NAME=SavageJokeBot
UPLOAD_SCHEDULE=14:00
TIMEZONE=UTC
